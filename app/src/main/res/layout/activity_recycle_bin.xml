<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_app"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/recycle_bin_toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:minHeight="@dimen/toolbar_height"
        android:orientation="horizontal"
        android:paddingStart="@dimen/space_sm"
        android:paddingEnd="@dimen/space_sm">

        <ImageButton
            android:id="@+id/recycle_bin_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_icon_button"
            android:contentDescription="@string/button_back"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_back" />

        <TextView
            android:id="@+id/recycle_bin_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="@dimen/space_sm"
            android:paddingEnd="@dimen/space_xs"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/file_browser_recycle_bin"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_section"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/recycle_bin_clear"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_button_secondary"
            android:clickable="true"
            android:focusable="true"
            android:minHeight="40dp"
            android:paddingStart="@dimen/space_md"
            android:paddingTop="@dimen/space_xs"
            android:paddingEnd="@dimen/space_md"
            android:paddingBottom="@dimen/space_xs"
            android:text="@string/file_browser_recycle_bin_clear"
            android:textAllCaps="false"
            android:textColor="@color/status_warning"
            android:textSize="@dimen/text_caption"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/recycle_bin_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/space_md"
        android:paddingEnd="@dimen/space_md"
        android:paddingBottom="@dimen/space_xs"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/text_caption" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycle_bin_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/space_md"
        android:scrollbars="vertical" />

    <LinearLayout
        android:id="@+id/recycle_bin_empty_panel"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/file_browser_recycle_bin_empty"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_body" />
    </LinearLayout>

</LinearLayout>
