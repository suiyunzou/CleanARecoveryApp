<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_app"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/file_browser_toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:minHeight="@dimen/toolbar_height"
        android:orientation="horizontal"
        android:paddingStart="@dimen/space_sm"
        android:paddingEnd="@dimen/space_sm">

        <ImageButton
            android:id="@+id/file_browser_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_icon_button"
            android:contentDescription="@string/button_back"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_back" />

        <TextView
            android:id="@+id/file_browser_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="@dimen/space_sm"
            android:paddingEnd="@dimen/space_xs"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/file_browser_title"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_section"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/file_browser_sort"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_icon_button"
            android:contentDescription="@string/file_browser_sort_name"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_sort" />

        <ImageButton
            android:id="@+id/file_browser_up"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_icon_button"
            android:contentDescription="@string/file_browser_up"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_up" />

        <ImageButton
            android:id="@+id/file_browser_new_folder"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_icon_button"
            android:contentDescription="@string/file_browser_new_folder"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_new_folder" />

        <ImageButton
            android:id="@+id/file_browser_recycle_bin"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_icon_button"
            android:contentDescription="@string/file_browser_recycle_bin"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_recycle_bin" />

        <ImageButton
            android:id="@+id/file_browser_select"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_icon_button"
            android:contentDescription="@string/file_browser_select"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_select" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/file_browser_multiselect_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/badge_existing_bg"
        android:gravity="center_vertical"
        android:minHeight="@dimen/toolbar_height"
        android:orientation="horizontal"
        android:paddingStart="@dimen/space_md"
        android:paddingEnd="@dimen/space_md"
        android:visibility="gone">

        <TextView
            android:id="@+id/file_browser_selected_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/badge_existing_text"
            android:textSize="@dimen/text_body"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/file_browser_batch_delete"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_button_secondary"
            android:clickable="true"
            android:focusable="true"
            android:minHeight="40dp"
            android:paddingStart="@dimen/space_md"
            android:paddingTop="@dimen/space_xs"
            android:paddingEnd="@dimen/space_md"
            android:paddingBottom="@dimen/space_xs"
            android:text="@string/file_browser_delete"
            android:textAllCaps="false"
            android:textColor="@color/status_warning"
            android:textSize="@dimen/text_caption"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/file_browser_cancel_select"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_sm"
            android:background="@drawable/bg_button_secondary"
            android:clickable="true"
            android:focusable="true"
            android:minHeight="40dp"
            android:paddingStart="@dimen/space_md"
            android:paddingTop="@dimen/space_xs"
            android:paddingEnd="@dimen/space_md"
            android:paddingBottom="@dimen/space_xs"
            android:text="@string/file_browser_cancel_select"
            android:textAllCaps="false"
            android:textColor="@color/brand_primary_dark"
            android:textSize="@dimen/text_caption"
            android:textStyle="bold" />
    </LinearLayout>

    <HorizontalScrollView
        android:id="@+id/file_browser_breadcrumb_scroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="true"
        android:paddingStart="@dimen/space_md"
        android:paddingEnd="@dimen/space_md"
        android:paddingBottom="@dimen/space_xs"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/file_browser_breadcrumb"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal" />
    </HorizontalScrollView>

    <EditText
        android:id="@+id/file_browser_search"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_md"
        android:layout_marginEnd="@dimen/space_md"
        android:layout_marginBottom="@dimen/space_sm"
        android:background="@drawable/bg_card"
        android:hint="@string/file_browser_search_hint"
        android:imeOptions="actionDone"
        android:inputType="text"
        android:maxLines="1"
        android:paddingStart="@dimen/space_md"
        android:paddingTop="@dimen/space_sm"
        android:paddingEnd="@dimen/space_md"
        android:paddingBottom="@dimen/space_sm"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_muted"
        android:textSize="@dimen/text_body" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/file_browser_list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:padding="@dimen/space_sm" />

        <LinearLayout
            android:id="@+id/file_browser_empty_panel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/space_xl"
            android:visibility="gone">

            <ImageView
                android:id="@+id/file_browser_empty_illustration"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:contentDescription="@null"
                android:src="@drawable/ill_empty_folder" />

            <TextView
                android:id="@+id/file_browser_empty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:gravity="center"
                android:text="@string/file_browser_empty"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_body" />
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
