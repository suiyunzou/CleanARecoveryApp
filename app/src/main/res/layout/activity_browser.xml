<?xml version="1.0" encoding="utf-8"?>
<!-- 内置浏览器布局：顶部地址栏 + WebView + 底部嗅探结果面板 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_app"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <!-- 顶部工具栏：返回 + 地址栏 + 嗅探按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:minHeight="@dimen/toolbar_height"
        android:orientation="horizontal"
        android:paddingStart="@dimen/space_sm"
        android:paddingEnd="@dimen/space_sm">

        <ImageButton
            android:id="@+id/browser_back_button"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_icon_button"
            android:contentDescription="@string/button_back"
            android:padding="12dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_back" />

        <EditText
            android:id="@+id/browser_url_input"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="@dimen/space_sm"
            android:layout_weight="1"
            android:background="@drawable/bg_input_field"
            android:hint="@string/browser_url_hint"
            android:imeOptions="actionGo"
            android:inputType="textUri"
            android:maxLines="1"
            android:paddingHorizontal="@dimen/space_md"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_muted"
            android:textSize="@dimen/text_body" />

        <ImageButton
            android:id="@+id/browser_go_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="@dimen/space_sm"
            android:background="@drawable/bg_icon_button"
            android:contentDescription="@string/browser_go"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_arrow_up" />
    </LinearLayout>

    <!-- 第二行：导航按钮 + 嗅探状态 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/space_sm"
        android:paddingBottom="@dimen/space_sm">

        <ImageButton
            android:id="@+id/browser_nav_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_icon_button"
            android:contentDescription="@string/browser_nav_back"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_back" />

        <ImageButton
            android:id="@+id/browser_nav_forward"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="@dimen/space_sm"
            android:background="@drawable/bg_icon_button"
            android:contentDescription="@string/browser_nav_forward"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_arrow_up"
            android:rotation="90" />

        <ImageButton
            android:id="@+id/browser_refresh"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="@dimen/space_sm"
            android:background="@drawable/bg_icon_button"
            android:contentDescription="@string/browser_refresh"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_arrow_up"
            android:rotation="180" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/browser_sniffer_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_trust_badge"
            android:paddingHorizontal="@dimen/space_md"
            android:paddingVertical="@dimen/space_xs"
            android:text="@string/browser_sniffer_count_zero"
            android:textColor="@color/text_muted"
            android:textSize="@dimen/text_caption"
            android:visibility="gone" />
    </LinearLayout>

    <!-- WebView 容器 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <WebView
            android:id="@+id/browser_webview"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- 加载进度条 -->
        <ProgressBar
            android:id="@+id/browser_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:layout_gravity="top"
            android:max="100"
            android:progress="0"
            android:progressTint="@color/brand_accent"
            android:visibility="gone" />

        <!-- 空状态提示 -->
        <TextView
            android:id="@+id/browser_empty_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:padding="@dimen/space_xl"
            android:text="@string/browser_empty_hint"
            android:textColor="@color/text_muted"
            android:textSize="@dimen/text_body"
            android:visibility="visible" />
    </FrameLayout>

    <!-- 底部嗅探结果面板（默认隐藏，发现媒体时显示） -->
    <LinearLayout
        android:id="@+id/browser_sniffer_panel"
        android:layout_width="match_parent"
        android:layout_height="360dp"
        android:background="@color/surface_card"
        android:elevation="@dimen/elevation_card"
        android:orientation="vertical"
        android:padding="@dimen/space_lg"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/browser_sniffer_title"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_section"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/browser_sniffer_close"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_icon_button"
                android:contentDescription="@string/browser_close_panel"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_back"
                android:rotation="90" />
        </LinearLayout>

        <TextView
            android:id="@+id/browser_sniffer_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xs"
            android:text="@string/browser_sniffer_hint"
            android:textColor="@color/text_muted"
            android:textSize="@dimen/text_caption" />

        <!-- 媒体列表 -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/space_md"
            android:layout_weight="1">

            <LinearLayout
                android:id="@+id/browser_media_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>

        <Button
            android:id="@+id/browser_download_all"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="@dimen/space_md"
            android:background="@drawable/bg_button_primary"
            android:backgroundTint="@color/brand_accent"
            android:text="@string/browser_download_selected"
            android:textAllCaps="false"
            android:textColor="@color/surface_card"
            android:textSize="@dimen/text_body" />
    </LinearLayout>

</LinearLayout>
