<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="@dimen/space_md"
    android:background="@drawable/bg_card">

    <FrameLayout
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_card">

        <TextView
            android:id="@+id/song_row_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="♪"
            android:textSize="16sp"
            android:textColor="@color/brand_primary" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_md"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/song_row_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_body" />

            <TextView
                android:id="@+id/song_row_vip_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_sm"
                android:background="@drawable/bg_badge_existing"
                android:gravity="center"
                android:paddingHorizontal="5dp"
                android:paddingVertical="1dp"
                android:text="VIP"
                android:textColor="@color/badge_existing_text"
                android:textSize="9sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/song_row_artist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_caption" />
    </LinearLayout>

    <TextView
        android:id="@+id/song_row_duration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_sm"
        android:gravity="end"
        android:textColor="@color/text_muted"
        android:textSize="@dimen/text_caption" />

    <!-- Edit-mode controls: move up / move down / remove -->
    <LinearLayout
        android:id="@+id/song_row_edit_controls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_sm"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone">

        <ImageButton
            android:id="@+id/song_row_up"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/music_move_up"
            android:src="@drawable/ic_back"
            android:rotation="-90"
            android:tint="@color/text_secondary" />

        <ImageButton
            android:id="@+id/song_row_down"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/music_move_down"
            android:src="@drawable/ic_back"
            android:rotation="90"
            android:tint="@color/text_secondary" />

        <ImageButton
            android:id="@+id/song_row_remove"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/music_remove_from_playlist"
            android:src="@drawable/ic_nav_results"
            android:tint="@color/accent_orange" />
    </LinearLayout>
</LinearLayout>
