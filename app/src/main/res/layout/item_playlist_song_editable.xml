<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:background="@drawable/bg_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="@dimen/space_md">

    <CheckBox
        android:id="@+id/song_row_checkbox"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:buttonTint="@color/brand_primary"
        android:visibility="gone" />

    <FrameLayout
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_card">

        <TextView
            android:id="@+id/song_row_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="♪"
            android:textColor="@color/brand_primary"
            android:textSize="16sp" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_md"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/song_row_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_body" />

            <TextView
                android:id="@+id/song_row_vip_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_sm"
                android:background="@drawable/bg_badge_existing"
                android:gravity="center"
                android:paddingHorizontal="5dp"
                android:paddingVertical="1dp"
                android:text="VIP"
                android:textColor="@color/badge_existing_text"
                android:textSize="9sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/song_row_artist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_caption" />
    </LinearLayout>

    <TextView
        android:id="@+id/song_row_duration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_sm"
        android:gravity="end"
        android:textColor="@color/text_muted"
        android:textSize="@dimen/text_caption" />

    <ImageButton
        android:id="@+id/song_row_drag_handle"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="@dimen/space_sm"
        android:background="@android:color/transparent"
        android:contentDescription="@string/music_sort_custom"
        android:src="@drawable/ic_drag_handle"
        android:tint="@color/text_secondary"
        android:visibility="gone" />
</LinearLayout>
