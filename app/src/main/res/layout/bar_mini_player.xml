<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="@dimen/music_mini_player_height"
    android:background="@color/music_mini_player_bg"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="@dimen/space_md"
    android:elevation="4dp"
    android:clickable="true"
    android:focusable="true">

    <!-- Left: previous song -->
    <ImageButton
        android:id="@+id/mini_player_prev"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@android:color/transparent"
        android:contentDescription="@string/preview_prev"
        android:src="@drawable/ic_skip_previous"
        android:tint="@color/text_secondary" />

    <!-- Center: icon (top, horizontally centered) + title/artist (bottom, centered).
         Vertical layout so the icon sits at the horizontal center of the bar. -->
    <LinearLayout
        android:id="@+id/mini_player_center"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:clickable="true"
        android:focusable="true">

        <FrameLayout
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/bg_card">

            <TextView
                android:id="@+id/mini_player_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="♪"
                android:textSize="16sp" />
        </FrameLayout>

        <TextView
            android:id="@+id/mini_player_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:textColor="@color/text_primary"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Right: next song -->
    <ImageButton
        android:id="@+id/mini_player_next"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@android:color/transparent"
        android:contentDescription="@string/preview_next"
        android:src="@drawable/ic_skip_next"
        android:tint="@color/text_secondary" />
</LinearLayout>
