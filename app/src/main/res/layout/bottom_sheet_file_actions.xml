<?xml version="1.0" encoding="utf-8"?>
<!-- 文件管理 V2：单项操作 BottomSheet -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:paddingTop="@dimen/space_sm"
    android:paddingBottom="@dimen/space_sm">

    <!-- 顶部拖动指示条 -->
    <View
        android:layout_width="32dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/space_xs"
        android:layout_marginBottom="@dimen/space_sm"
        android:background="@drawable/bg_alg_status_dot"
        android:backgroundTint="@color/neutral_light" />

    <!-- 标题：文件名 -->
    <TextView
        android:id="@+id/bottom_sheet_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="middle"
        android:maxLines="1"
        android:paddingStart="@dimen/space_lg"
        android:paddingTop="@dimen/space_sm"
        android:paddingEnd="@dimen/space_lg"
        android:paddingBottom="@dimen/space_md"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_section"
        android:textStyle="bold" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginBottom="@dimen/space_xs"
        android:background="@color/border_subtle" />

    <!-- 打开方式 -->
    <LinearLayout
        android:id="@+id/action_open_with"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="?android:attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/space_lg"
        android:paddingEnd="@dimen/space_lg">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_open_with"
            android:tint="@color/text_primary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/space_lg"
            android:text="@string/file_browser_open_with"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_section" />
    </LinearLayout>

    <!-- 重命名 -->
    <LinearLayout
        android:id="@+id/action_rename"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="?android:attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/space_lg"
        android:paddingEnd="@dimen/space_lg">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_edit"
            android:tint="@color/text_primary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/space_lg"
            android:text="@string/file_browser_rename"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_section" />
    </LinearLayout>

    <!-- 分享 -->
    <LinearLayout
        android:id="@+id/action_share"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="?android:attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/space_lg"
        android:paddingEnd="@dimen/space_lg">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_share"
            android:tint="@color/text_primary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/space_lg"
            android:text="@string/file_browser_share"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_section" />
    </LinearLayout>

    <!-- 详情 -->
    <LinearLayout
        android:id="@+id/action_details"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="?android:attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/space_lg"
        android:paddingEnd="@dimen/space_lg">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_info"
            android:tint="@color/text_primary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/space_lg"
            android:text="@string/file_browser_details"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_section" />
    </LinearLayout>

    <!-- 分隔线 + 破坏性操作 -->
    <View
        android:id="@+id/bottom_sheet_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="@dimen/space_xs"
        android:layout_marginBottom="@dimen/space_xs"
        android:background="@color/border_subtle" />

    <LinearLayout
        android:id="@+id/action_delete"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="?android:attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/space_lg"
        android:paddingEnd="@dimen/space_lg">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_delete"
            android:tint="@color/accent_red" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/space_lg"
            android:text="@string/file_browser_delete"
            android:textColor="@color/accent_red"
            android:textSize="@dimen/text_section" />
    </LinearLayout>
</LinearLayout>
