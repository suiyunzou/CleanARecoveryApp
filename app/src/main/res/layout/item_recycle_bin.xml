<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card"
    android:gravity="center_vertical"
    android:minHeight="64dp"
    android:orientation="horizontal"
    android:paddingStart="@dimen/space_md"
    android:paddingTop="@dimen/space_sm"
    android:paddingEnd="@dimen/space_md"
    android:paddingBottom="@dimen/space_sm">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/recycle_item_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_body"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/recycle_item_path"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="start"
            android:maxLines="1"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_caption" />

        <TextView
            android:id="@+id/recycle_item_meta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_caption" />
    </LinearLayout>

    <TextView
        android:id="@+id/recycle_item_restore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_sm"
        android:background="@drawable/bg_button_secondary"
        android:clickable="true"
        android:focusable="true"
        android:minHeight="40dp"
        android:paddingStart="@dimen/space_md"
        android:paddingTop="@dimen/space_xs"
        android:paddingEnd="@dimen/space_md"
        android:paddingBottom="@dimen/space_xs"
        android:text="@string/file_browser_recycle_bin_restore"
        android:textAllCaps="false"
        android:textColor="@color/brand_primary_dark"
        android:textSize="@dimen/text_caption"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/recycle_item_delete"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_sm"
        android:background="@drawable/bg_button_secondary"
        android:clickable="true"
        android:focusable="true"
        android:minHeight="40dp"
        android:paddingStart="@dimen/space_md"
        android:paddingTop="@dimen/space_xs"
        android:paddingEnd="@dimen/space_md"
        android:paddingBottom="@dimen/space_xs"
        android:text="@string/file_browser_recycle_bin_delete_permanent"
        android:textAllCaps="false"
        android:textColor="@color/status_warning"
        android:textSize="@dimen/text_caption"
        android:textStyle="bold" />

</LinearLayout>
