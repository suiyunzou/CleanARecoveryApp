<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_app"
    android:fitsSystemWindows="true"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="@dimen/space_xl">

        <ImageView
            android:layout_width="220dp"
            android:layout_height="160dp"
            android:contentDescription="@string/onboarding_title"
            android:scaleType="centerInside"
            android:src="@drawable/ill_onboarding_permission" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="@dimen/space_lg"
            android:text="@string/onboarding_title"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_title"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="@dimen/space_md"
            android:text="@string/onboarding_bullet_accessible"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_body" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="@dimen/space_sm"
            android:text="@string/onboarding_bullet_copy_only"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_body" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="@dimen/space_sm"
            android:text="@string/onboarding_bullet_no_root"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_body" />

        <Button
            android:id="@+id/onboarding_grant_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xl"
            android:background="@drawable/bg_button_primary"
            android:minHeight="@dimen/button_min_height"
            android:text="@string/button_grant_access"
            android:textAllCaps="false"
            android:textColor="@color/text_on_primary" />
    </LinearLayout>
</ScrollView>
