<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_app"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <FrameLayout
        android:id="@+id/main_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ScrollView
            android:id="@+id/home_panel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="@dimen/space_md">

                <LinearLayout
                    android:id="@+id/permission_banner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_permission_banner_ok"
                    android:orientation="vertical"
                    android:padding="@dimen/space_md">

                    <TextView
                        android:id="@+id/permission_banner_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/storage_access_granted"
                        android:textColor="@color/status_success"
                        android:textSize="@dimen/text_body"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/permission_banner_action"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingTop="@dimen/space_xs"
                        android:text="@string/button_grant_access"
                        android:textColor="@color/text_muted"
                        android:textSize="@dimen/text_caption"
                        android:visibility="gone" />
                </LinearLayout>

                <TextView
                    android:id="@+id/last_scan_summary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_sm"
                    android:layout_marginBottom="@dimen/space_xs"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/last_scan_empty"
                    android:textColor="@color/text_muted"
                    android:textSize="@dimen/text_micro" />

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md"
                    android:columnCount="2"
                    android:rowCount="2">

                    <include
                        android:id="@+id/card_images"
                        layout="@layout/item_category_card"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="@dimen/space_xs" />

                    <include
                        android:id="@+id/card_videos"
                        layout="@layout/item_category_card"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="@dimen/space_xs" />

                    <include
                        android:id="@+id/card_audio"
                        layout="@layout/item_category_card"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="@dimen/space_xs" />

                    <include
                        android:id="@+id/card_documents"
                        layout="@layout/item_category_card"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="@dimen/space_xs" />
                </GridLayout>

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:minHeight="@dimen/space_sm" />

                <Button
                    android:id="@+id/scan_all_button"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="@dimen/space_sm"
                    android:background="@drawable/bg_button_primary"
                    android:text="@string/scan_all_button"
                    android:textAllCaps="false"
                    android:textColor="@color/text_on_primary" />

                <LinearLayout
                    android:id="@+id/experimental_scan_button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_sm"
                    android:background="@drawable/bg_button_experimental"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="60dp"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/space_md"
                    android:paddingEnd="@dimen/space_md">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:contentDescription="@string/experimental_scan_button"
                        android:src="@drawable/ic_experimental_recovery" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="@dimen/space_md">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/experimental_scan_button"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:paddingTop="2dp"
                            android:text="@string/experimental_scan_hint"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_caption" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <LinearLayout
            android:id="@+id/scan_panel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="#FF111827"
            android:visibility="gone">

            <com.example.cleanrecovery.ui.widget.ParticleScanView
                android:id="@+id/scan_particle_view"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <Button
                android:id="@+id/stop_scan_button"
                android:layout_width="240dp"
                android:layout_height="44dp"
                android:layout_gravity="center"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_button_secondary"
                android:text="@string/button_stop"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/results_panel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:minHeight="@dimen/toolbar_height"
                android:orientation="horizontal"
                android:paddingStart="@dimen/space_sm"
                android:paddingEnd="@dimen/space_md">

                <ImageButton
                    android:id="@+id/results_back_button"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_icon_button"
                    android:contentDescription="@string/button_back"
                    android:padding="12dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_back" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:paddingStart="@dimen/space_sm"
                    android:text="@string/results_title"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_section"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/results_status_filter_button"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_results_chip_unselected"
                    android:drawableStart="@drawable/ic_filter"
                    android:drawablePadding="6dp"
                    android:gravity="center"
                    android:paddingStart="@dimen/space_md"
                    android:paddingEnd="@dimen/space_md"
                    android:text="@string/results_status_filter"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_caption"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/selection_action_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_results_action_bar"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="@dimen/space_md"
                android:paddingTop="@dimen/space_sm"
                android:paddingEnd="@dimen/space_md"
                android:paddingBottom="@dimen/space_sm"
                android:visibility="gone">

                <TextView
                    android:id="@+id/selected_count"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_body"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/select_all_button"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_results_chip_unselected"
                    android:gravity="center"
                    android:paddingStart="@dimen/space_md"
                    android:paddingEnd="@dimen/space_md"
                    android:text="@string/button_select_all"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_caption"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/clear_selection_button"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_results_chip_unselected"
                    android:gravity="center"
                    android:paddingStart="@dimen/space_md"
                    android:paddingEnd="@dimen/space_md"
                    android:text="@string/button_clear"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_caption"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/recover_button"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_button_primary"
                    android:gravity="center"
                    android:paddingStart="@dimen/space_lg"
                    android:paddingEnd="@dimen/space_lg"
                    android:text="@string/recover_to_datarecovery"
                    android:textColor="@color/text_on_primary"
                    android:textSize="@dimen/text_caption"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginStart="@dimen/space_md"
                android:layout_marginTop="@dimen/space_xs"
                android:layout_marginEnd="@dimen/space_md"
                android:background="@drawable/bg_results_summary"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="@dimen/space_md"
                android:paddingEnd="@dimen/space_md">

                <TextView
                    android:id="@+id/results_summary_scope"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_caption"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/results_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/results_summary_deleted"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/results_summary_output"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="gone" />
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:paddingStart="@dimen/space_md"
                android:paddingTop="@dimen/space_md"
                android:paddingEnd="@dimen/space_md"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/filter_type_row"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/filter_type_all"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginEnd="@dimen/space_sm"
                        android:background="@drawable/bg_results_chip_selected"
                        android:gravity="center"
                        android:minWidth="72dp"
                        android:paddingStart="@dimen/space_lg"
                        android:paddingEnd="@dimen/space_lg"
                        android:textColor="@color/text_on_primary"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/filter_type_images"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginEnd="@dimen/space_sm"
                        android:background="@drawable/bg_results_chip_unselected"
                        android:gravity="center"
                        android:minWidth="72dp"
                        android:paddingStart="@dimen/space_lg"
                        android:paddingEnd="@dimen/space_lg"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/filter_type_videos"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginEnd="@dimen/space_sm"
                        android:background="@drawable/bg_results_chip_unselected"
                        android:gravity="center"
                        android:minWidth="72dp"
                        android:paddingStart="@dimen/space_lg"
                        android:paddingEnd="@dimen/space_lg"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/filter_type_audio"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginEnd="@dimen/space_sm"
                        android:background="@drawable/bg_results_chip_unselected"
                        android:gravity="center"
                        android:minWidth="72dp"
                        android:paddingStart="@dimen/space_lg"
                        android:paddingEnd="@dimen/space_lg"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/filter_type_documents"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_results_chip_unselected"
                        android:gravity="center"
                        android:minWidth="72dp"
                        android:paddingStart="@dimen/space_lg"
                        android:paddingEnd="@dimen/space_lg"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold" />
                </LinearLayout>
            </HorizontalScrollView>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/results_grid"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:paddingStart="@dimen/space_md"
                    android:paddingTop="@dimen/space_md"
                    android:paddingEnd="@dimen/space_md"
                    android:paddingBottom="@dimen/space_lg" />

                <LinearLayout
                    android:id="@+id/results_empty"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/space_lg"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="104dp"
                        android:layout_height="104dp"
                        android:contentDescription="@string/empty_results_title"
                        android:scaleType="centerInside"
                        android:src="@drawable/ill_empty_results" />

                    <TextView
                        android:id="@+id/results_empty_message"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:maxLines="2"
                        android:paddingTop="@dimen/space_sm"
                        android:text="@string/empty_results_title"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_body" />

                    <Button
                        android:id="@+id/rescan_button"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:background="@drawable/bg_button_primary"
                        android:minHeight="@dimen/button_min_height"
                        android:paddingStart="@dimen/space_xl"
                        android:paddingEnd="@dimen/space_xl"
                        android:text="@string/rescan_button"
                        android:textAllCaps="false"
                        android:textColor="@color/text_on_primary" />
                </LinearLayout>
            </FrameLayout>

        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bottom_nav"
        android:elevation="8dp"
        android:minHeight="@dimen/bottom_nav_height"
        android:orientation="horizontal"
        android:paddingTop="@dimen/space_xs"
        android:paddingBottom="@dimen/space_xs">

        <LinearLayout
            android:id="@+id/nav_home"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/space_xs">

            <ImageView
                android:id="@+id/nav_home_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/nav_home"
                android:src="@drawable/ic_nav_home" />

            <TextView
                android:id="@+id/nav_home_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingTop="2dp"
                android:text="@string/nav_home"
                android:textColor="@color/brand_primary"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_results"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/space_xs">

            <ImageView
                android:id="@+id/nav_results_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/nav_results"
                android:src="@drawable/ic_nav_results" />

            <TextView
                android:id="@+id/nav_results_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingTop="2dp"
                android:text="@string/nav_results"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_folder"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/space_xs">

            <ImageView
                android:id="@+id/nav_folder_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/nav_folder"
                android:src="@drawable/ic_nav_folder" />

            <TextView
                android:id="@+id/nav_folder_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingTop="2dp"
                android:text="@string/nav_folder"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_about"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/space_xs">

            <ImageView
                android:id="@+id/nav_about_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/nav_about"
                android:src="@drawable/ic_nav_about" />

            <TextView
                android:id="@+id/nav_about_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingTop="2dp"
                android:text="@string/nav_about"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
