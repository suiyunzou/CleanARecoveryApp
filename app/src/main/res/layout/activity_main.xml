<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_app"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <FrameLayout
        android:id="@+id/main_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ScrollView
            android:id="@+id/home_panel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:minHeight="@dimen/toolbar_height"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/app_name"
                        android:textColor="@color/brand_primary"
                        android:textSize="@dimen/text_title"
                        android:textStyle="bold" />

                    <ImageButton
                        android:id="@+id/home_settings_button"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_icon_button"
                        android:contentDescription="@string/about_title"
                        android:padding="12dp"
                        android:scaleType="centerInside"
                        android:src="@android:drawable/ic_menu_info_details"
                        android:tint="@color/text_secondary" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="@dimen/space_md"
                    android:text="@string/app_subtitle"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_caption" />

                <LinearLayout
                    android:id="@+id/permission_banner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_permission_banner_ok"
                    android:orientation="vertical"
                    android:padding="@dimen/space_md">

                    <TextView
                        android:id="@+id/permission_banner_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/storage_access_granted"
                        android:textColor="@color/status_success"
                        android:textSize="@dimen/text_body"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/permission_banner_action"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingTop="@dimen/space_xs"
                        android:text="@string/trust_non_destructive"
                        android:textColor="@color/text_muted"
                        android:textSize="@dimen/text_caption" />
                </LinearLayout>

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_lg"
                    android:columnCount="2"
                    android:rowCount="2">

                    <include
                        android:id="@+id/card_images"
                        layout="@layout/item_category_card"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="@dimen/space_xs" />

                    <include
                        android:id="@+id/card_videos"
                        layout="@layout/item_category_card"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="@dimen/space_xs" />

                    <include
                        android:id="@+id/card_audio"
                        layout="@layout/item_category_card"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="@dimen/space_xs" />

                    <include
                        android:id="@+id/card_documents"
                        layout="@layout/item_category_card"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="@dimen/space_xs" />
                </GridLayout>

                <Button
                    android:id="@+id/scan_all_button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md"
                    android:background="@drawable/bg_button_primary"
                    android:minHeight="@dimen/button_min_height"
                    android:text="@string/scan_all_button"
                    android:textAllCaps="false"
                    android:textColor="@color/text_on_primary" />

                <Button
                    android:id="@+id/experimental_scan_button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_sm"
                    android:background="@drawable/bg_button_experimental"
                    android:minHeight="@dimen/button_min_height"
                    android:text="@string/experimental_scan_button"
                    android:textAllCaps="false"
                    android:textColor="@color/status_warning" />

                <LinearLayout
                    android:id="@+id/last_scan_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_lg"
                    android:background="@drawable/bg_card"
                    android:elevation="@dimen/elevation_card"
                    android:orientation="vertical"
                    android:padding="@dimen/space_md">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/last_scan_title"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_section"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/last_scan_summary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingTop="@dimen/space_sm"
                        android:text="@string/last_scan_empty"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_body" />
                </LinearLayout>

                <Button
                    android:id="@+id/open_output_button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md"
                    android:background="@drawable/bg_button_secondary"
                    android:minHeight="@dimen/button_min_height"
                    android:text="@string/open_data_recovery_folder"
                    android:textAllCaps="false"
                    android:textColor="@color/brand_primary_dark" />
            </LinearLayout>
        </ScrollView>

        <LinearLayout
            android:id="@+id/scan_panel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="@dimen/space_xl"
            android:visibility="gone">

            <TextView
                android:id="@+id/scan_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/scan_status"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_section"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/scan_phase_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:gravity="center"
                android:text="@string/scan_phase_preparing"
                android:textColor="@color/brand_primary_dark"
                android:textSize="@dimen/text_body"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/scan_percent"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0%"
                    android:textColor="@color/brand_primary"
                    android:textSize="42sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/scan_eta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:text="@string/scan_eta_calculating"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_body" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/scan_progress_bar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="14dp"
                android:layout_marginTop="@dimen/space_md"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/progress_scan" />

            <TextView
                android:id="@+id/scan_detail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:gravity="center"
                android:textColor="@color/text_muted"
                android:textSize="@dimen/text_caption" />

            <TextView
                android:id="@+id/scan_stats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:gravity="center"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_body" />

            <TextView
                android:id="@+id/scan_path_toggle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:gravity="center"
                android:text="@string/show_current_path"
                android:textColor="@color/brand_primary_dark"
                android:textSize="@dimen/text_caption" />

            <TextView
                android:id="@+id/scan_current_path"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:fontFamily="monospace"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:visibility="gone" />

            <Button
                android:id="@+id/stop_scan_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xl"
                android:background="@drawable/bg_button_secondary"
                android:minHeight="@dimen/button_min_height"
                android:text="@string/button_stop"
                android:textAllCaps="false"
                android:textColor="@color/brand_primary_dark" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/results_panel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:minHeight="@dimen/toolbar_height"
                android:orientation="horizontal"
                android:paddingStart="@dimen/space_sm"
                android:paddingEnd="@dimen/space_md">

                <ImageButton
                    android:id="@+id/results_back_button"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_icon_button"
                    android:contentDescription="@string/button_back"
                    android:padding="12dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_back" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:paddingStart="@dimen/space_sm"
                    android:text="@string/results_title"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_section"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/results_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_caption" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/filter_tabs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="@dimen/space_md"
                android:paddingEnd="@dimen/space_md"
                android:paddingBottom="@dimen/space_sm">

                <Button
                    android:id="@+id/filter_all_button"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="@dimen/space_xs"
                    android:layout_weight="1"
                    android:background="@drawable/bg_tab_selected"
                    android:text="@string/filter_all"
                    android:textAllCaps="false"
                    android:textSize="@dimen/text_caption" />

                <Button
                    android:id="@+id/filter_existing_button"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="@dimen/space_xs"
                    android:layout_weight="1"
                    android:background="@drawable/bg_tab_unselected"
                    android:text="@string/filter_existing"
                    android:textAllCaps="false"
                    android:textSize="@dimen/text_caption" />

                <Button
                    android:id="@+id/filter_deleted_button"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_tab_unselected"
                    android:text="@string/filter_deleted"
                    android:textAllCaps="false"
                    android:textSize="@dimen/text_caption" />
            </LinearLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/results_grid"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:padding="@dimen/space_sm" />

                <LinearLayout
                    android:id="@+id/results_empty"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/space_xl"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="160dp"
                        android:layout_height="160dp"
                        android:contentDescription="@string/empty_results_title"
                        android:scaleType="centerInside"
                        android:src="@drawable/ill_empty_results" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingTop="@dimen/space_md"
                        android:text="@string/empty_results_title"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_section" />

                    <Button
                        android:id="@+id/rescan_button"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:background="@drawable/bg_button_primary"
                        android:minHeight="@dimen/button_min_height"
                        android:paddingStart="@dimen/space_xl"
                        android:paddingEnd="@dimen/space_xl"
                        android:text="@string/rescan_button"
                        android:textAllCaps="false"
                        android:textColor="@color/text_on_primary" />
                </LinearLayout>
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/surface_card"
                android:elevation="6dp"
                android:orientation="vertical"
                android:padding="@dimen/space_md">

                <TextView
                    android:id="@+id/selected_count"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_caption" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="@dimen/space_sm">

                    <Button
                        android:id="@+id/select_all_button"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/space_xs"
                        android:layout_weight="1"
                        android:background="@drawable/bg_button_secondary"
                        android:text="@string/button_select_all"
                        android:textAllCaps="false"
                        android:textSize="@dimen/text_caption" />

                    <Button
                        android:id="@+id/clear_selection_button"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/space_xs"
                        android:layout_weight="1"
                        android:background="@drawable/bg_button_secondary"
                        android:text="@string/button_clear"
                        android:textAllCaps="false"
                        android:textSize="@dimen/text_caption" />

                    <Button
                        android:id="@+id/recover_button"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.4"
                        android:background="@drawable/bg_button_primary"
                        android:text="@string/button_recover"
                        android:textAllCaps="false"
                        android:textColor="@color/text_on_primary"
                        android:textSize="@dimen/text_caption" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bottom_nav"
        android:elevation="8dp"
        android:minHeight="@dimen/bottom_nav_height"
        android:orientation="horizontal"
        android:paddingTop="@dimen/space_xs"
        android:paddingBottom="@dimen/space_xs">

        <LinearLayout
            android:id="@+id/nav_home"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/space_xs">

            <ImageView
                android:id="@+id/nav_home_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/nav_home"
                android:src="@drawable/ic_nav_home" />

            <TextView
                android:id="@+id/nav_home_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingTop="2dp"
                android:text="@string/nav_home"
                android:textColor="@color/brand_primary"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_results"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/space_xs">

            <ImageView
                android:id="@+id/nav_results_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/nav_results"
                android:src="@drawable/ic_nav_results" />

            <TextView
                android:id="@+id/nav_results_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingTop="2dp"
                android:text="@string/nav_results"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_folder"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/space_xs">

            <ImageView
                android:id="@+id/nav_folder_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/nav_folder"
                android:src="@drawable/ic_nav_folder" />

            <TextView
                android:id="@+id/nav_folder_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingTop="2dp"
                android:text="@string/nav_folder"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_about"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/space_xs">

            <ImageView
                android:id="@+id/nav_about_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/nav_about"
                android:src="@drawable/ic_nav_about" />

            <TextView
                android:id="@+id/nav_about_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingTop="2dp"
                android:text="@string/nav_about"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
