<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_card"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/toolbar_height"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/space_md">

        <ImageButton
            android:id="@+id/player_back_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_icon_button"
            android:contentDescription="@string/button_back"
            android:src="@drawable/ic_back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_md"
            android:layout_weight="1"
            android:text="@string/music_now_playing"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_section" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/player_cover_panel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/space_xl">

            <FrameLayout
                android:layout_width="@dimen/music_cover_lg"
                android:layout_height="@dimen/music_cover_lg"
                android:background="@drawable/bg_album_cover_circle"
                android:clipToOutline="true">

                <ImageView
                    android:id="@+id/player_cover_image"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/music_now_playing"
                    android:scaleType="centerCrop"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/player_cover_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="♪"
                    android:textColor="@color/brand_primary"
                    android:textSize="48sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <TextView
                android:id="@+id/player_song_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/player_song_artist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_body" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xl"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/player_current_lyric"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:gravity="center"
                        android:maxLines="1"
                        android:text="@string/music_lyrics_empty"
                        android:textColor="@color/brand_primary"
                        android:textSize="@dimen/text_body"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/player_next_lyric"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:ellipsize="end"
                        android:gravity="center"
                        android:maxLines="1"
                        android:textColor="@color/text_muted"
                        android:textSize="@dimen/text_caption" />
                </LinearLayout>

                <ImageButton
                    android:id="@+id/player_more_button"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="@dimen/space_sm"
                    android:background="@drawable/bg_icon_button"
                    android:contentDescription="@string/music_more_actions"
                    android:src="@drawable/ic_settings_gear"
                    android:tint="@color/text_secondary" />
            </LinearLayout>

            <TextView
                android:id="@+id/player_status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:textColor="@color/text_muted"
                android:textSize="@dimen/text_caption"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/player_lyrics_panel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical"
            android:visibility="gone">

            <com.example.cleanrecovery.music.ui.LyricsView
                android:id="@+id/player_lyrics_view"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingTop="@dimen/space_xl"
                android:paddingBottom="@dimen/space_xl" />

            <TextView
                android:id="@+id/player_lyrics_empty"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/music_lyrics_empty"
                android:textColor="@color/music_text_empty"
                android:textSize="@dimen/text_body"
                android:visibility="gone" />
        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/space_xl"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/player_current_time"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0:00"
            android:textColor="@color/text_muted"
            android:textSize="@dimen/text_caption" />

        <ImageButton
            android:id="@+id/player_lyrics_settings"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/music_lyrics_settings"
            android:src="@drawable/ic_tune_sliders"
            android:tint="@color/text_secondary" />

        <TextView
            android:id="@+id/player_total_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_sm"
            android:text="0:00"
            android:textColor="@color/text_muted"
            android:textSize="@dimen/text_caption" />
    </LinearLayout>

    <SeekBar
        android:id="@+id/player_seekbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/space_xl"
        android:max="1000"
        android:progressTint="@color/music_progress_fill"
        android:thumbTint="@color/brand_primary" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_md"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/player_prev_button"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_skip_previous" />

        <ImageButton
            android:id="@+id/player_play_button"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginHorizontal="@dimen/space_xl"
            android:background="@drawable/bg_button_primary"
            android:backgroundTint="@color/brand_primary"
            android:scaleType="center"
            android:src="@drawable/ic_play_white"
            android:tint="@color/surface_card" />

        <ImageButton
            android:id="@+id/player_next_button"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_skip_next" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/space_xl"
        android:layout_marginTop="@dimen/space_md"
        android:layout_marginBottom="@dimen/space_md"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/player_mode_button"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_icon_button"
            android:contentDescription="@string/music_mode"
            android:src="@drawable/ic_repeat"
            android:tint="@color/text_secondary" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/player_queue_button"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_icon_button"
            android:contentDescription="@string/music_queue"
            android:src="@drawable/ic_queue_music"
            android:tint="@color/text_secondary" />
    </LinearLayout>
</LinearLayout>
