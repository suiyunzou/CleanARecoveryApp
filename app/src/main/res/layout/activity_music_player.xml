<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_card"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/toolbar_height"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/space_md">

        <ImageButton
            android:id="@+id/player_back_button"
            android:layout_width="40dp" android:layout_height="40dp"
            android:background="@drawable/bg_icon_button"
            android:src="@drawable/ic_back" />

        <TextView
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_md"
            android:layout_weight="1"
            android:text="@string/music_now_playing"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_section" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="@dimen/music_cover_lg"
        android:layout_height="@dimen/music_cover_lg"
        android:layout_gravity="center"
        android:layout_marginTop="@dimen/space_xl"
        android:background="@drawable/bg_card">

        <TextView
            android:id="@+id/player_cover_text"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="🎵"
            android:textSize="48sp" />
    </FrameLayout>

    <TextView
        android:id="@+id/player_song_title"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="@dimen/space_lg"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/player_song_artist"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="4dp"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/text_body" />

    <SeekBar
        android:id="@+id/player_seekbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/space_xl"
        android:layout_marginTop="@dimen/space_lg"
        android:max="1000"
        android:progressTint="@color/music_progress_fill"
        android:thumbTint="@color/brand_primary" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/space_xl"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/player_current_time"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0:00"
            android:textColor="@color/text_muted"
            android:textSize="@dimen/text_caption" />

        <TextView
            android:id="@+id/player_total_time"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="0:00"
            android:textColor="@color/text_muted"
            android:textSize="@dimen/text_caption" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_lg"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/player_mode_button"
            android:layout_width="48dp" android:layout_height="48dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_nav_results"
            android:tint="@color/text_secondary" />

        <ImageButton
            android:id="@+id/player_prev_button"
            android:layout_width="56dp" android:layout_height="56dp"
            android:layout_marginStart="@dimen/space_lg"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_back" />

        <ImageButton
            android:id="@+id/player_play_button"
            android:layout_width="64dp" android:layout_height="64dp"
            android:layout_marginStart="@dimen/space_lg"
            android:background="@drawable/bg_button_primary"
            android:backgroundTint="@color/brand_primary"
            android:src="@drawable/ic_type_audio"
            android:tint="@color/surface_card" />

        <ImageButton
            android:id="@+id/player_next_button"
            android:layout_width="56dp" android:layout_height="56dp"
            android:layout_marginStart="@dimen/space_lg"
            android:background="@android:color/transparent"
            android:rotation="180"
            android:src="@drawable/ic_back" />

        <ImageButton
            android:id="@+id/player_fav_button"
            android:layout_width="48dp" android:layout_height="48dp"
            android:layout_marginStart="@dimen/space_lg"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_nav_folder"
            android:tint="@color/text_secondary" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_lg"
        android:gravity="center"
        android:orientation="horizontal">

        <Button
            android:id="@+id/player_add_to_playlist_button"
            android:layout_width="wrap_content" android:layout_height="40dp"
            android:background="@drawable/bg_tab_unselected"
            android:paddingHorizontal="@dimen/space_lg"
            android:text="@string/music_add_to_playlist"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_caption" />
    </LinearLayout>

</LinearLayout>
