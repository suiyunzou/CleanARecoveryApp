<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_card"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/toolbar_height"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/space_md">

        <ImageButton
            android:id="@+id/player_back_button"
            android:layout_width="40dp" android:layout_height="40dp"
            android:background="@drawable/bg_icon_button"
            android:contentDescription="@string/button_back"
            android:src="@drawable/ic_back" />

        <TextView
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_md"
            android:layout_weight="1"
            android:text="@string/music_now_playing"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_section" />

        <ImageButton
            android:id="@+id/player_lyrics_toggle"
            android:layout_width="40dp" android:layout_height="40dp"
            android:background="@drawable/bg_icon_button"
            android:contentDescription="@string/music_lyrics"
            android:src="@drawable/ic_lyrics"
            android:tint="@color/text_secondary" />

        <ImageButton
            android:id="@+id/player_download_button"
            android:layout_width="40dp" android:layout_height="40dp"
            android:background="@drawable/bg_icon_button"
            android:contentDescription="@string/music_download"
            android:src="@drawable/ic_download"
            android:tint="@color/text_secondary" />
    </LinearLayout>

    <!-- Cover + lyrics share the upper area. When lyrics are visible the cover
         shrinks; otherwise it stays large. -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Default cover view -->
        <LinearLayout
            android:id="@+id/player_cover_panel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="@dimen/music_cover_lg"
                android:layout_height="@dimen/music_cover_lg"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/space_lg"
                android:background="@drawable/bg_card">

                <TextView
                    android:id="@+id/player_cover_text"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="🎵"
                    android:textSize="48sp" />
            </FrameLayout>

            <TextView
                android:id="@+id/player_song_title"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/space_lg"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/player_song_artist"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="4dp"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_body" />

            <TextView
                android:id="@+id/player_status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/space_sm"
                android:textColor="@color/text_muted"
                android:textSize="@dimen/text_caption"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Lyrics panel (hidden by default) -->
        <LinearLayout
            android:id="@+id/player_lyrics_panel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <com.example.cleanrecovery.music.ui.LyricsView
                android:id="@+id/player_lyrics_view"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingTop="@dimen/space_xl"
                android:paddingBottom="@dimen/space_xl" />

            <TextView
                android:id="@+id/player_lyrics_empty"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/music_lyrics_empty"
                android:textColor="@color/music_text_empty"
                android:textSize="@dimen/text_body"
                android:visibility="gone" />

            <!-- Lyrics font size + color controls -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingVertical="@dimen/space_sm">

                <Button
                    android:id="@+id/player_lyrics_font"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_tab_unselected"
                    android:paddingHorizontal="@dimen/space_lg"
                    android:text="@string/music_lyrics_font_size"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_caption" />

                <Button
                    android:id="@+id/player_lyrics_color"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="@dimen/space_md"
                    android:background="@drawable/bg_tab_unselected"
                    android:paddingHorizontal="@dimen/space_lg"
                    android:text="@string/music_lyrics_color"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_caption" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <SeekBar
        android:id="@+id/player_seekbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/space_xl"
        android:layout_marginTop="@dimen/space_sm"
        android:max="1000"
        android:progressTint="@color/music_progress_fill"
        android:thumbTint="@color/brand_primary" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/space_xl"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/player_current_time"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0:00"
            android:textColor="@color/text_muted"
            android:textSize="@dimen/text_caption" />

        <TextView
            android:id="@+id/player_total_time"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="0:00"
            android:textColor="@color/text_muted"
            android:textSize="@dimen/text_caption" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_md"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/player_mode_button"
            android:layout_width="48dp" android:layout_height="48dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_repeat"
            android:tint="@color/text_secondary" />

        <ImageButton
            android:id="@+id/player_prev_button"
            android:layout_width="56dp" android:layout_height="56dp"
            android:layout_marginStart="@dimen/space_lg"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_skip_previous" />

        <ImageButton
            android:id="@+id/player_play_button"
            android:layout_width="64dp" android:layout_height="64dp"
            android:layout_marginStart="@dimen/space_lg"
            android:background="@drawable/bg_button_primary"
            android:backgroundTint="@color/brand_primary"
            android:src="@drawable/ic_play_white"
            android:tint="@color/surface_card"
            android:scaleType="center" />

        <ImageButton
            android:id="@+id/player_next_button"
            android:layout_width="56dp" android:layout_height="56dp"
            android:layout_marginStart="@dimen/space_lg"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_skip_next" />

        <ImageButton
            android:id="@+id/player_fav_button"
            android:layout_width="48dp" android:layout_height="48dp"
            android:layout_marginStart="@dimen/space_lg"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_favorite"
            android:tint="@color/text_secondary" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_md"
        android:layout_marginBottom="@dimen/space_md"
        android:gravity="center"
        android:orientation="horizontal">

        <Button
            android:id="@+id/player_add_to_playlist_button"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:background="@drawable/bg_tab_unselected"
            android:paddingHorizontal="@dimen/space_lg"
            android:text="@string/music_add_to_playlist"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_caption" />
    </LinearLayout>

</LinearLayout>
