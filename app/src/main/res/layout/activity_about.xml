<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_app"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:minHeight="@dimen/toolbar_height"
            android:orientation="horizontal"
            android:paddingStart="@dimen/space_sm"
            android:paddingEnd="@dimen/space_sm">

            <ImageButton
                android:id="@+id/about_back_button"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_icon_button"
                android:contentDescription="@string/button_back"
                android:padding="12dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_back" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingStart="@dimen/space_sm"
                android:text="@string/about_title"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_section"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/about_share_button"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_icon_button"
                android:contentDescription="@string/about_share"
                android:padding="12dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_share" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_xl"
            android:layout_marginTop="@dimen/space_md"
            android:layout_marginEnd="@dimen/space_xl"
            android:background="@drawable/bg_about_hero"
            android:clipToOutline="true"
            android:orientation="vertical"
            android:paddingStart="@dimen/space_lg"
            android:paddingTop="@dimen/space_xl"
            android:paddingEnd="@dimen/space_lg"
            android:paddingBottom="@dimen/space_xl">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:background="@drawable/bg_about_logo"
                    android:contentDescription="@string/app_name"
                    android:padding="@dimen/space_sm"
                    android:scaleType="centerInside"
                    android:src="@mipmap/ic_launcher" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_lg"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/app_name"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_title"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/about_version"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_xs"
                        android:background="@drawable/bg_about_version"
                        android:paddingStart="@dimen/space_md"
                        android:paddingTop="@dimen/space_xs"
                        android:paddingEnd="@dimen/space_md"
                        android:paddingBottom="@dimen/space_xs"
                        android:textColor="@color/brand_primary_dark"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                android:text="@string/about_tagline"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_section"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:lineSpacingMultiplier="1.45"
                android:text="@string/about_body"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_body" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_xl"
            android:layout_marginTop="@dimen/space_lg"
            android:layout_marginEnd="@dimen/space_xl"
            android:background="@drawable/bg_about_panel"
            android:orientation="vertical"
            android:padding="@dimen/space_sm">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="@dimen/space_sm"
                android:paddingTop="@dimen/space_xs"
                android:paddingEnd="@dimen/space_sm"
                android:paddingBottom="@dimen/space_sm"
                android:text="@string/about_tools_title"
                android:textColor="@color/text_muted"
                android:textSize="@dimen/text_micro"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/about_music_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_about_row"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:minHeight="76dp"
                android:orientation="horizontal"
                android:paddingStart="@dimen/space_md"
                android:paddingTop="@dimen/space_md"
                android:paddingEnd="@dimen/space_md"
                android:paddingBottom="@dimen/space_md">

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_about_icon_teal"
                    android:contentDescription="@string/music_home_title"
                    android:padding="@dimen/space_md"
                    android:src="@drawable/ic_type_audio"
                    android:tint="@color/brand_primary" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_md"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/music_home_title"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_body"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/about_music_desc"
                        android:textColor="@color/text_muted"
                        android:textSize="@dimen/text_caption" />
                </LinearLayout>

                <Button
                    android:id="@+id/about_music_entry"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_about_action_teal"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:paddingStart="@dimen/space_lg"
                    android:paddingEnd="@dimen/space_lg"
                    android:text="@string/about_music_open"
                    android:textAllCaps="false"
                    android:textColor="@color/brand_primary_dark"
                    android:textSize="@dimen/text_caption"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="64dp"
                android:background="@color/border_subtle" />

            <LinearLayout
                android:id="@+id/about_online_movie_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_about_row"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:minHeight="76dp"
                android:orientation="horizontal"
                android:paddingStart="@dimen/space_md"
                android:paddingTop="@dimen/space_md"
                android:paddingEnd="@dimen/space_md"
                android:paddingBottom="@dimen/space_md">

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_about_icon_blue"
                    android:contentDescription="@string/online_movie_title"
                    android:padding="@dimen/space_md"
                    android:src="@drawable/ic_type_video"
                    android:tint="@color/brand_accent" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_md"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/online_movie_title"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_body"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/about_online_movie_desc"
                        android:textColor="@color/text_muted"
                        android:textSize="@dimen/text_caption" />
                </LinearLayout>

                <Button
                    android:id="@+id/about_online_movie_entry"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_about_action_blue"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:paddingStart="@dimen/space_lg"
                    android:paddingEnd="@dimen/space_lg"
                    android:text="@string/about_music_open"
                    android:textAllCaps="false"
                    android:textColor="@color/brand_accent"
                    android:textSize="@dimen/text_caption"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="64dp"
                android:background="@color/border_subtle" />

            <LinearLayout
                android:id="@+id/about_universal_download_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_about_row"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:minHeight="76dp"
                android:orientation="horizontal"
                android:paddingStart="@dimen/space_md"
                android:paddingTop="@dimen/space_md"
                android:paddingEnd="@dimen/space_md"
                android:paddingBottom="@dimen/space_md">

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_about_icon_blue"
                    android:contentDescription="@string/universal_download_title"
                    android:padding="@dimen/space_md"
                    android:src="@drawable/ic_download"
                    android:tint="@color/brand_accent" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_md"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/universal_download_title"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_body"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/about_universal_download_desc"
                        android:textColor="@color/text_muted"
                        android:textSize="@dimen/text_caption" />
                </LinearLayout>

                <Button
                    android:id="@+id/about_universal_download_entry"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_about_action_blue"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:paddingStart="@dimen/space_lg"
                    android:paddingEnd="@dimen/space_lg"
                    android:text="@string/about_music_open"
                    android:textAllCaps="false"
                    android:textColor="@color/brand_accent"
                    android:textSize="@dimen/text_caption"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_xl"
            android:layout_marginTop="@dimen/space_lg"
            android:layout_marginEnd="@dimen/space_xl"
            android:background="@drawable/bg_about_trust"
            android:baselineAligned="false"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="@dimen/space_sm"
            android:paddingTop="@dimen/space_md"
            android:paddingEnd="@dimen/space_sm"
            android:paddingBottom="@dimen/space_md">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/about_badge_no_root"
                android:textColor="@color/status_success"
                android:textSize="@dimen/text_caption"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/about_badge_read_only"
                android:textColor="@color/status_success"
                android:textSize="@dimen/text_caption"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/about_badge_safe"
                android:textColor="@color/status_success"
                android:textSize="@dimen/text_caption"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xl"
            android:layout_marginBottom="@dimen/space_xl"
            android:gravity="center"
            android:text="@string/about_footer"
            android:textColor="@color/text_muted"
            android:textSize="@dimen/text_micro" />
    </LinearLayout>
</ScrollView>
