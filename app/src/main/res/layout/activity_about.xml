<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_app"
    android:fitsSystemWindows="true"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:minHeight="@dimen/toolbar_height"
            android:orientation="horizontal"
            android:paddingStart="@dimen/space_sm"
            android:paddingEnd="@dimen/space_sm">

            <ImageButton
                android:id="@+id/about_back_button"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_icon_button"
                android:contentDescription="@string/button_back"
                android:padding="12dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_back" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingStart="@dimen/space_sm"
                android:text="@string/about_title"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_section"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/about_share_button"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_icon_button"
                android:contentDescription="@string/about_share"
                android:padding="12dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_share" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingTop="@dimen/space_xl">

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:contentDescription="@string/app_name"
                android:scaleType="centerInside"
                android:src="@mipmap/ic_launcher" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingTop="@dimen/space_md"
                android:text="@string/app_name"
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/about_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingTop="@dimen/space_xs"
                android:textColor="@color/text_muted"
                android:textSize="@dimen/text_caption" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_xl"
            android:layout_marginTop="@dimen/space_lg"
            android:layout_marginEnd="@dimen/space_xl"
            android:background="@drawable/bg_card"
            android:elevation="@dimen/elevation_card"
            android:orientation="vertical"
            android:padding="@dimen/space_lg">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/about_tagline"
                android:textColor="@color/brand_primary_dark"
                android:textSize="@dimen/text_section"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="@dimen/space_md"
                android:text="@string/about_body"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_body"
                android:lineSpacingMultiplier="1.5" />
        </LinearLayout>

        <!-- Music entry -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_xl"
            android:layout_marginTop="@dimen/space_md"
            android:layout_marginEnd="@dimen/space_xl"
            android:background="@drawable/bg_card"
            android:elevation="@dimen/elevation_card"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/space_lg">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:contentDescription="@string/music_home_title"
                android:src="@drawable/ic_type_audio"
                android:tint="@color/brand_primary" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_md"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/music_home_title"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_section"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/about_music_desc"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_caption" />
            </LinearLayout>

            <Button
                android:id="@+id/about_music_entry"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/bg_button_primary"
                android:backgroundTint="@color/brand_primary"
                android:paddingHorizontal="@dimen/space_lg"
                android:text="@string/about_music_open"
                android:textAllCaps="false"
                android:textColor="@color/surface_card"
                android:textSize="@dimen/text_caption"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_xl"
            android:layout_marginTop="@dimen/space_md"
            android:layout_marginEnd="@dimen/space_xl"
            android:background="@drawable/bg_card"
            android:elevation="@dimen/elevation_card"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="@dimen/space_lg">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_trust_badge"
                android:gravity="center"
                android:paddingStart="@dimen/space_md"
                android:paddingTop="@dimen/space_xs"
                android:paddingEnd="@dimen/space_md"
                android:paddingBottom="@dimen/space_xs"
                android:text="@string/about_badge_no_root"
                android:textColor="@color/status_success"
                android:textSize="@dimen/text_caption"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_sm"
                android:background="@drawable/bg_trust_badge"
                android:gravity="center"
                android:paddingStart="@dimen/space_md"
                android:paddingTop="@dimen/space_xs"
                android:paddingEnd="@dimen/space_md"
                android:paddingBottom="@dimen/space_xs"
                android:text="@string/about_badge_read_only"
                android:textColor="@color/status_success"
                android:textSize="@dimen/text_caption"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_sm"
                android:background="@drawable/bg_trust_badge"
                android:gravity="center"
                android:paddingStart="@dimen/space_md"
                android:paddingTop="@dimen/space_xs"
                android:paddingEnd="@dimen/space_md"
                android:paddingBottom="@dimen/space_xs"
                android:text="@string/about_badge_safe"
                android:textColor="@color/status_success"
                android:textSize="@dimen/text_caption"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xl"
            android:layout_marginBottom="@dimen/space_xl"
            android:gravity="center"
            android:text="@string/about_footer"
            android:textColor="@color/text_muted"
            android:textSize="@dimen/text_micro" />
    </LinearLayout>
</ScrollView>
